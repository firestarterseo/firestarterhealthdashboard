# Required for the app to run at all
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Ads integration (account-level daily spend/conversions in the sync-metrics cron).
# Developer token comes from the manager (MCC) account's API Center: ads.google.com/aw/apicenter
# LOGIN_CUSTOMER_ID is that same manager account's ID, digits only (no dashes).
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Required for the daily alert digest email (app/api/cron/check-alerts)
RESEND_API_KEY=
ALERT_TO_EMAILS=          # comma-separated, e.g. jeff@firestarterseo.com,skyler@firestarterseo.com

# Optional — defaults to alerts@firestarterseo.com if unset.
# Must be on a domain verified in Resend; the shared onboarding@resend.dev sender
# can only deliver to the Resend account owner's own email, not a real recipient list.
ALERT_FROM_EMAIL=
